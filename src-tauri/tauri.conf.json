{
    "$schema":  "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName":  "Pixel Studio",
    "version":  "2.0.0",
    "identifier":  "com.pixelstudio.app",
    "build":  {
                  "frontendDist":  "..",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "",
                  "beforeBuildCommand":  ""
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Pixel Studio",
                                    "width":  1024,
                                    "height":  768,
                                    "minWidth":  800,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; script-src \u0027self\u0027 \u0027unsafe-inline\u0027 https://cdn.jsdelivr.net; style-src \u0027self\u0027 \u0027unsafe-inline\u0027"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icon.svg"
                            ]
               }
}
